# ============================================================================
# UÇ OPTİK DOĞRULAMA SİSTEMİ (UODS) - ORTAM DEĞİŞKENLERİ ŞABLONU
# ============================================================================
# Bu dosyayı ".env" adıyla kopyalayıp kendi değerlerinizle doldurun:
#   cp .env.example .env
#
# UYARI: .env dosyasını ASLA versiyon kontrolüne (Git) eklemeyin.
# Bu proje, .gitignore içinde .env dosyasını dışlamaktadır.
# ============================================================================

# --- Flask Sunucu Ayarları -------------------------------------------------
FLASK_ENV=development
FLASK_SECRET_KEY=degistirilmesi-zorunlu-cok-gizli-bir-anahtar-uretin
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
MAX_UPLOAD_SIZE_MB=15

# --- Kurumsal Anonimleştirme (KVKK) -----------------------------------------
# Bu tuz (salt) değeri kurumunuza özeldir ve sızdırılmamalıdır.
# k = SHA-256(TC || isim_normalize || tarih || KURUM_TUZU)
KURUM_TUZU=BU_DEGERI_DEGISTIRIN_COK_GIZLI_RASTGELE_BIR_DIZE_URETIN
KURUM_ADI=SILSILE-TEKNOFEST-PILOT-KURUM

# --- IPFS / Pinata Ayarları --------------------------------------------------
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- Blokzincir (Polygon) Ayarları ------------------------------------------
# Alchemy/Infura vb. servislerden alınan Polygon Amoy Testnet RPC adresi
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/SIZIN_ALCHEMY_API_KEYINIZ
POLYGON_CHAIN_ID=80002

# Kurumun yetkili (relayer) cüzdanına ait ÖZEL ANAHTAR (0x ile başlamalı).
# BU DEĞER SON DERECE GİZLİDİR. Asla paylaşmayın, asla repoya eklemeyin.
INSTITUTION_PRIVATE_KEY=0xBU_DEGERI_DEGISTIRIN_GERCEK_ANAHTARINIZI_BURAYA_YAZMAYIN

# Akıllı sözleşmenin deploy edildiği adres (scripts/deploy_contract.py ile
# deploy ettikten sonra buraya yazılır)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Gas fiyatlandırması (gwei, EIP-1559 öncelik ücreti)
MAX_PRIORITY_FEE_GWEI=30
MAX_FEE_GWEI=60

# --- Çevrimdışı Tampon (SQLite) ----------------------------------------------
SQLITE_DB_PATH=instance/uods_queue.db
SYNC_INTERVAL_SECONDS=15
SYNC_MAX_RETRY=5

# --- OMR Yapılandırması ------------------------------------------------------
OMR_TEMPLATE_PATH=config/omr_template.json

# --- /verify Ekranı Erişim Koruması (HTTP Basic Auth) ------------------------
# Her ikisi de tanımlıysa /verify ekranı HTTP Basic Auth ile korunur.
# Tanımlı değilse ekran açık kalır ve bunu görünür bir uyarı olarak gösterir
# — ÜRETİME ALMADAN ÖNCE BU İKİSİNİ TANIMLAMANIZ ZORUNLUDUR.
#
# INSTITUTION_VERIFY_PASSWORD_HASH değerini üretmek için:
#   python3 -c "from werkzeug.security import generate_password_hash as g; print(g('SEÇTİĞİNİZ_ŞİFRE'))"
# Çıkan hash'i (düz şifreyi DEĞİL) buraya yapıştırın.
INSTITUTION_VERIFY_USERNAME=
INSTITUTION_VERIFY_PASSWORD_HASH=

# --- Loglama -------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Hata İzleme (Sentry, isteğe bağlı) -----------------------------------------
# Boş bırakılırsa Sentry devre dışı kalır (uygulama normal çalışır).
# Sentry'ye KVKK kapsamında kişisel veri (TC/isim) GÖNDERİLMEZ
# (bkz. app.py: send_default_pii=False).
SENTRY_DSN=
